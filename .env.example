# =============================================================================
# BLOOD DONATION APP — ENVIRONMENT VARIABLES
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development           # development | staging | production
PORT=3000
CORS_ORIGIN=http://localhost:8081

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL 16 + PostGIS
# Local dev: docker compose spins this up automatically
# Prod (Neon): use -pooler host for DATABASE_URL, bare host for DIRECT_URL.
# DIRECT_URL must point to the non-pooled endpoint so Prisma Migrate can run
# DDL directly (PgBouncer/Neon pooler does not support DDL via prepared stmts).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://dev:dev@localhost:5432/blooddonation
DIRECT_URL=postgresql://dev:dev@localhost:5432/blooddonation

# -----------------------------------------------------------------------------
# REDIS — Upstash (prod) or local Redis (dev)
# Local dev: docker compose spins this up automatically
# Prod: rediss://<token>@<host>.upstash.io:6380  (note: rediss:// with TLS)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT — RS256 asymmetric signing
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w 0 private.pem   → JWT_PRIVATE_KEY
#   base64 -w 0 public.pem    → JWT_PUBLIC_KEY
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=<base64-encoded-rsa2048-private-key>
JWT_PUBLIC_KEY=<base64-encoded-rsa2048-public-key>
JWT_ACCESS_TTL=900             # seconds — 15 minutes
JWT_REFRESH_TTL=604800         # seconds — 7 days

# -----------------------------------------------------------------------------
# SMS — MSG91 (primary, India DLT) → Twilio (fallback) → Console (dev)
# SMS_PROVIDER=console sends OTPs to server logs only — safe for local dev
# MSG91 DLT registration required for production (see docs/launch-checklist.md)
# -----------------------------------------------------------------------------
SMS_PROVIDER=console           # console | msg91 | twilio

MSG91_AUTH_KEY=                # MSG91 dashboard → API → Auth Key
MSG91_SENDER_ID=               # 6-char DLT-registered sender ID e.g. BLDDON
MSG91_TEMPLATE_ID=             # DLT-registered OTP template ID

TWILIO_ACCOUNT_SID=            # Twilio console → Account SID
TWILIO_AUTH_TOKEN=             # Twilio console → Auth Token
TWILIO_FROM_NUMBER=            # E.164 e.g. +12025551234

# -----------------------------------------------------------------------------
# FIREBASE CLOUD MESSAGING — Push notifications (free tier)
# Download service account JSON from Firebase console → Project Settings → Service accounts
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=               # JSON private_key field (with newlines as \n)
FCM_CLIENT_EMAIL=              # JSON client_email field

# -----------------------------------------------------------------------------
# STORAGE — Cloudflare R2 (S3-compatible, no egress fees)
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# -----------------------------------------------------------------------------
R2_ENDPOINT=
R2_ACCESS_KEY_ID=              # R2 API token → Access Key ID
R2_SECRET_ACCESS_KEY=          # R2 API token → Secret Access Key
R2_BUCKET=blooddonation

# -----------------------------------------------------------------------------
# GEOCODING — Nominatim (OpenStreetMap, free, no API key needed)
# Results are cached in Postgres (GeocodeCache table)
# Do not hammer the public endpoint — cache handles repeat queries
# -----------------------------------------------------------------------------
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# -----------------------------------------------------------------------------
# EMAIL — SendGrid free tier (100 emails/day) or Resend free tier
# Use SENDGRID_API_KEY or RESEND_API_KEY — not both
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@blooddonation.app

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
SENTRY_DSN=                    # Sentry project → Settings → Client Keys
SENTRY_ENVIRONMENT=development # development | staging | production

# Grafana Cloud Prometheus remote-write (metrics)
GRAFANA_PROMETHEUS_URL=
GRAFANA_PROMETHEUS_USER=
GRAFANA_PROMETHEUS_TOKEN=

# -----------------------------------------------------------------------------
# ADMIN SECURITY
# -----------------------------------------------------------------------------
ADMIN_ALLOWED_IPS=127.0.0.1   # Comma-separated CIDRs for admin endpoint allowlist
                               # Production: your office/VPN IPs only

# -----------------------------------------------------------------------------
# RATE LIMITING (defaults match Blueprint §9.3 — override per environment)
# -----------------------------------------------------------------------------
RATE_LIMIT_SEND_OTP_PER_HOUR=5
RATE_LIMIT_VERIFY_OTP_PER_5MIN=3
RATE_LIMIT_CREATE_REQUEST_PER_HOUR=10
RATE_LIMIT_REPORT_PER_DAY=5
RATE_LIMIT_DEFAULT_PER_MIN=100
