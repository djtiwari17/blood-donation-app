{
  "name": "blood-donation",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "backend": "npm run start:dev --workspace=apps/backend",
    "admin": "npm run dev --workspace=apps/admin",
    "test:unit": "npm run test:unit --workspace=apps/backend",
    "test:e2e": "npm run test:e2e --workspace=apps/backend",
    "lint": "npm run lint --workspace=apps/backend",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
